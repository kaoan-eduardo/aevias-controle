{
  "name": "DriveFolderMap",
  "type": "object",
  "properties": {
    "path_key": {
      "type": "string",
      "description": "Unique key like 'root', 'obra_<obraId>', 'obra_<obraId>_<entityType>'"
    },
    "folder_id": {
      "type": "string",
      "description": "Google Drive folder ID"
    },
    "folder_name": {
      "type": "string",
      "description": "Human-readable name of the folder"
    }
  },
  "required": [
    "path_key",
    "folder_id"
  ]
}