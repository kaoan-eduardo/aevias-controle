{
  "name": "ChecklistUsina",
  "type": "object",
  "properties": {
    "obra_id": {
      "type": "string",
      "description": "ID da obra"
    },
    "project_id": {
      "type": "string",
      "description": "ID do Projeto vinculado"
    },
    "data": {
      "type": "string",
      "format": "date",
      "description": "Data do checklist"
    },
    "jornada": {
      "type": "object",
      "description": "Jornada de trabalho do funcion\u00e1rio",
      "properties": {
        "horario_inicio": {
          "type": "string"
        },
        "horario_fim": {
          "type": "string"
        }
      }
    },
    "laboratorista_name": {
      "type": "string"
    },
    "usina": {
      "type": "string",
      "description": "Nome da usina"
    },
    "projeto_utilizado": {
      "type": "string"
    },
    "faixa_especificada": {
      "type": "string"
    },
    "ligante": {
      "type": "string"
    },
    "pedreira": {
      "type": "string"
    },
    "inspetor_campo": {
      "type": "string"
    },
    "engenheiro_responsavel": {
      "type": "string"
    },
    "controle_agregados": {
      "type": "array",
      "description": "Controle din\u00e2mico de agregados",
      "items": {
        "type": "object"
      }
    },
    "equivalente_areia_status": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "realizado",
        "nao_realizado",
        null
      ],
      "default": null
    },
    "equivalente_areia_quantidade": {
      "type": "number",
      "default": 0
    },
    "equivalente_areia_resultados": {
      "type": "array",
      "items": {
        "type": "number"
      }
    },
    "observacoes_agregados": {
      "type": "string"
    },
    "rodadas_producao": {
      "type": "array",
      "description": "Rodadas de produ\u00e7\u00e3o (at\u00e9 4)",
      "items": {
        "type": "object"
      }
    },
    "controle_cauq": {
      "type": "object",
      "description": "Controle de CAUQ"
    },
    "controle_ligante_ativo": {
      "type": "boolean",
      "default": false
    },
    "controle_ligante": {
      "type": "object",
      "properties": {
        "nota_fiscal": {
          "type": "string"
        },
        "fornecedor": {
          "type": "string"
        },
        "placa_carreta": {
          "type": "string"
        },
        "quantidade_toneladas": {
          "type": "number"
        },
